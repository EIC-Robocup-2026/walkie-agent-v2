# walkie-agent-v2 environment — copy to .env and fill in.
#
# .env now holds ONLY the OpenRouter secret + base URL. Everything else (LLM
# model/temperature, local-LLM endpoint, AI-server URL, robot transport, runtime
# toggles) lives in config.toml and is version-controlled. Anything set here or
# in the shell still overrides config.toml.

# --- LLM (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
