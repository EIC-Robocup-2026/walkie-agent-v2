# --- LLM (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
WALKIE_MODEL=anthropic/claude-sonnet-4.5
WALKIE_TEMPERATURE=0

# --- AI services (walkie-ai-server) ---
WALKIE_AI_BASE_URL=http://localhost:5000

# --- Storage ---
CHROMA_DIR=chroma_db
# Explore stage saves a JPEG crop of each promoted object's bbox here, and
# records the path in the object's `frame_ref` (shown by the Chroma viewer).
OBJECT_FRAMES_DIR=object_frames
PERCEPTION_PATH=perception.json

# --- Logging ---
# Perception log verbosity (scene loop ticks + scene.dedup + scene.prune). Leave
# unset and each entrypoint picks its own default: main.py = WARNING (quiet — keeps
# the logs from burying your prompt while commanding the robot); tools.scene_explore
# = INFO (verbose — watch it collect). Uncomment to force one level everywhere.
# WALKIE_LOG_LEVEL=WARNING

# --- Robot behavior ---
# Set to 1 to pause after each movement / arm action (debugging)
PAUSE_AFTER_WALK=0

# --- Explore stage thresholds ---
EXPLORE_INTERVAL_SEC=1.0
EXPLORE_MIN_SIGHTINGS=5
EXPLORE_DEDUP_RADIUS_M=1.0
EXPLORE_MIN_CONF=0.6

# --- Ready stage perception ---
PERCEPTION_INTERVAL_SEC=10.0
PERCEPTION_STALE_SEC=10
# Captions per object are expensive; off by default.
PERCEPTION_CAPTION_OBJECTS=0
# Comma-separated class names to caption (empty = all classes).
PERCEPTION_CAPTION_FILTER=""

# --- CLIP scene perception (long-term semantic memory, ready stage) ---
# Embeds detections via walkie-ai-server's /image-embed (CLIP) and stores them
# in a ChromaDB scene memory queried by find_object_from_memory.
# On startup the app probes /image-embed; if it's unavailable the loop is
# skipped automatically (the rest of the app runs normally).
SCENE_PERCEPTION_ENABLED=1
SCENE_CHROMA_DIR=chroma_db_scene
SCENE_FRAMES_DIR=frames
# Captioning is ~6s/tick, so a tiny interval just queues work; 10s keeps the
# AI-server load sane. Lower only if you need faster scene updates.
SCENE_PERCEPTION_INTERVAL_SEC=10.0
SCENE_MIN_CONF=0.0
# Dedup gates (perception/dedup.py). Lowered from the 0.5 / 0.2 defaults so
# closely-spaced same-class objects (e.g. several identical bottles on a table)
# stay as separate records instead of being merged.
#   TRADE-OFF: these must stay ABOVE the per-object position jitter from
#   get_3d_poses (~5-15cm) — otherwise the SAME object gets re-inserted as
#   duplicates across frames. If you see one object split into many records,
#   raise these back up. Verify counts per class in the chroma viewer.
SCENE_DEDUP_RADIUS_M=0.1
SCENE_DEDUP_TIGHT_M=0.08
# Embedding-similarity merge gates (cosine). The HIGH gate merges on visual
# similarity regardless of distance (within RADIUS); raise it toward 1.0 to
# merge less aggressively when distinct objects look alike.
SCENE_EMB_SIM_HIGH=0.85
SCENE_EMB_SIM_LOW=0.65
# Position stamped on each scene entry:
#   lift  = SDK depth+TF per-object 3D position (walkie.tools.bboxes_to_positions);
#           distinct objects get distinct positions so dedup won't collapse them.
#           Needs rosbridge + get_3d_poses up, else the tick is dropped (nothing stored).
#   robot = robot's own odom pose (coarse, robust; same pos for all objects in a
#           frame, so same-class objects merge — use only when get_3d_poses is down)
SCENE_POSITION_SOURCE=lift
# Per-object captions are expensive; off by default (uses one whole-frame caption).
SCENE_CAPTION_PER_OBJECT=0
# Refresh the archived thumbnail every time an object is re-seen, so the viewer
# shows its latest frame instead of the first-ever one. Overwrites in place (one
# JPEG per object), so it doesn't grow the frames/ dir. Set 0 to keep the
# original insert frame for the object's whole life.
SCENE_FRAME_REFRESH_ON_UPDATE=1

# --- Scene eviction / pruning (ready stage) ---
# Without this the scene store is append/update-only: objects you physically
# remove never leave the store (their last_seen_ts just stops advancing), so the
# viewer keeps showing stale records + old frames. The loop periodically calls
# SceneStore.prune to age them out.
#   SCENE_PRUNE_TTL_SEC    evict records not re-seen for this many seconds.
#                          0/empty/off disables TTL pruning entirely.
#   SCENE_PRUNE_RADIUS_M   spatial gate: only TTL-evict records within this many
#                          metres of the robot's CURRENT pose. This is what makes
#                          pruning safe while roaming — objects in rooms the robot
#                          hasn't revisited are out of range, so they're never
#                          wrongly deleted; they only age out once the robot is
#                          back near them and still doesn't see them. Set 0/empty
#                          for a GLOBAL TTL sweep (only safe for a fixed view).
#                          When a radius is set but the robot pose is unknown, the
#                          TTL sweep is skipped that cycle (never global).
#   SCENE_PRUNE_INTERVAL_SEC  how often the prune runs (wall clock).
#   SCENE_PRUNE_MAX_RECORDS   optional hard cap on total records (newest kept);
#                             empty = no cap. Applies globally, ignores radius.
# TUNING: TTL must comfortably exceed how long the robot looks away from an
# object that's still there, or it'll be evicted and re-inserted. With a 10s loop
# the default 60s TTL needs ~6 consecutive misses within radius before evicting.
SCENE_PRUNE_TTL_SEC=60
SCENE_PRUNE_RADIUS_M=2.5
SCENE_PRUNE_INTERVAL_SEC=10
SCENE_PRUNE_MAX_RECORDS=

# --- ChromaDB viewer (dev tool: `uv run python -m tools.chroma_viewer`) ---
# Read-only web UI to inspect the stores above. Reads, never writes.
CHROMA_VIEWER_DIRS=chroma_db,chroma_db_scene
CHROMA_VIEWER_PORT=8500
# Initial browser auto-refresh interval in seconds (0 = off). The dropdown in
# the header overrides this per-browser. Browse/substring updates pick up the
# robot's writes on each refresh; semantic (vector) search needs a restart.
CHROMA_VIEWER_REFRESH_SEC=5
