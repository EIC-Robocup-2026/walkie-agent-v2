# --- LLM (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
WALKIE_MODEL=anthropic/claude-sonnet-4.5
WALKIE_TEMPERATURE=0

# --- AI services (walkie-ai-server) ---
WALKIE_AI_BASE_URL=http://localhost:5000

# --- Storage ---
CHROMA_DIR=chroma_db
PERCEPTION_PATH=perception.json

# --- Robot behavior ---
# Set to 1 to pause after each movement / arm action (debugging)
PAUSE_AFTER_WALK=0

# --- Explore stage thresholds ---
EXPLORE_INTERVAL_SEC=1.0
EXPLORE_MIN_SIGHTINGS=5
EXPLORE_DEDUP_RADIUS_M=1.0
EXPLORE_MIN_CONF=0.6

# --- Ready stage perception ---
PERCEPTION_INTERVAL_SEC=10.0
PERCEPTION_STALE_SEC=10
# Captions per object are expensive; off by default.
PERCEPTION_CAPTION_OBJECTS=0
