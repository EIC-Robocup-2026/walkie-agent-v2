# walkie-agent-v2 environment — copy to .env and fill in.
#
# .env holds ONLY secrets, endpoints, and per-machine/runtime toggles.
# All tuning knobs (perception/scene/explore/viewer/model) live in config.toml
# and are version-controlled. Anything set here still overrides config.toml.

# --- LLM (OpenRouter, OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- AI services (walkie-ai-server) ---
WALKIE_AI_BASE_URL=http://localhost:5000

# --- Robot transport (walkie-sdk) ---
# ROS services over rosbridge (default), camera over zenoh. Force zenoh services
# only if you've shipped the perception/srv into zenoh_ros2_sdk. Port defaults to
# 9090 for rosbridge, 7447 for zenoh.
WALKIE_ROS_PROTOCOL=rosbridge
WALKIE_ROS_PORT=9090
# IP of the robot for the walkie-sdk transport (rosbridge + zenoh camera).
# Leave 127.0.0.1 when running on the robot itself; set to walkie's own LAN IP
# (e.g. 10.0.0.201) when running from a developer PC. Note: walkie is NOT the
# same machine as the AI server at WALKIE_AI_BASE_URL — they're separate boxes.
WALKIE_ROBOT_IP=127.0.0.1

# --- Runtime toggles ---
DISABLE_LISTENING=0         # 1 = type instructions instead of speaking (no mic)
